# ── Apache Unomi (remote CDP server) ─────────────────────────────────────
# Point to your deployed Unomi instance (no trailing slash).
# Example: https://unomi.your-domain.com:8181
UNOMI_BASE_URL=

# Scope must exist on the Unomi server (create in Unomi admin or use default scope).
UNOMI_SCOPE=inoyu-cdp-retirement

# v2 = classic Karaf REST + context API (most self-hosted deployments)
# v3 = tenant public token for context API (Inoyu / multi-tenant)
UNOMI_VERSION=v2

# Admin REST credentials (dashboard agent, profile search, health checks)
UNOMI_USERNAME=karaf
UNOMI_PASSWORD=karaf

# Optional: separate credentials for /health/check (defaults to UNOMI_USERNAME/PASSWORD)
# UNOMI_HEALTH_USERNAME=health
# UNOMI_HEALTH_PASSWORD=health

# v3 only: public tenant token for context.json event ingestion
UNOMI_TENANT_PUBLIC_TOKEN=

# Send basic auth on context.json calls (recommended for remote v2 servers)
UNOMI_CONTEXT_USE_ADMIN_AUTH=true

# Server logging: errors/warnings always log; debug needs LOG_LEVEL=debug or UNOMI_DEBUG=true
# LOG_LEVEL=debug
# UNOMI_DEBUG=true

# ── LLM — Infomaniak AI (recommended, EU-hosted, OpenAI-compatible) ───────────
# Create an API token in Infomaniak Manager (scope: AI Tools).
# Find your product id: GET https://api.infomaniak.com/1/ai (Authorization: Bearer token)
INFOMANIAK_API_TOKEN=
INFOMANIAK_AI_PRODUCT_ID=
# Model id from GET .../openai/v1/models — e.g. qwen3, llama3, mistral3, gemma3n
OPENAI_MODEL=qwen3

# ── LLM — other OpenAI-compatible providers (optional overrides) ─────────────
# If INFOMANIAK_AI_PRODUCT_ID is set, base URL is built automatically. Otherwise:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Azure: OPENAI_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT
# Azure auth: OPENAI_AUTH_SCHEME=Api-Key
# Azure: OPENAI_API_VERSION=2024-02-15-preview
# OPENAI_AUTH_SCHEME=Bearer
# OPENAI_ORGANIZATION=          # OpenAI.com only
# OPENAI_HTTP_REFERER=          # OpenRouter optional
# OPENAI_APP_TITLE=Inoyu CDP Retirement Demo

# Token cost estimate for marketer dashboard (USD per 1M tokens)
# OPENAI_COST_INPUT_PER_MTOK=0.15
# OPENAI_COST_OUTPUT_PER_MTOK=0.60

# ── Local demo helpers ─────────────────────────────────────────────────────
# Simulate IP country for region detection (ISO 3166-1 alpha-2, e.g. US, JP, CH)
DEMO_COUNTRY_CODE=

# ── Demo gate (tester login) ───────────────────────────────────────────────
# Every route except /login is protected. Testers share ONE password; the name
# they enter at login identifies them for silent usage analytics.
#
# DEMO_PASSWORD — shared password for all demo users (set before deploy)
#   Default "inoyu-demo-local" when unset — local dev only; set a strong value before deploy.
DEMO_PASSWORD=inoyu-demo-local
#
# DEMO_AUTH_SECRET — HMAC secret for signed session cookies (set before deploy)
#   Generate: openssl rand -hex 32
DEMO_AUTH_SECRET=change-me-in-production
