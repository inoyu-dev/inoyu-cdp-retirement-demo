{
  "name": "inoyu-cdp-retirement-demo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify:integrations": "node --env-file=.env.local scripts/verify-integrations.mjs",
    "test:smoke:prod": "node --env-file=.env.local scripts/smoke-production.mjs --strict",
    "deploy:vercel": "node scripts/deploy-vercel.mjs",
    "deploy:vercel:preview": "node scripts/deploy-vercel.mjs --preview",
    "vercel:env:sync": "node scripts/sync-vercel-env.mjs",
    "vercel:link": "vercel link --yes",
    "vercel:env:verify": "node scripts/verify-vercel-env.mjs",
    "verify:unomi": "node --env-file=.env.local scripts/verify-unomi-events.mjs",
    "verify:unomi:schemas": "node --env-file=.env.local scripts/verify-unomi-events.mjs --register-schemas",
    "cleanup:unomi": "node --env-file=.env.local scripts/cleanup-unomi-profiles.mjs",
    "cleanup:unomi:execute": "node --env-file=.env.local scripts/cleanup-unomi-profiles.mjs --execute",
    "test:integration": "node --test tests/integration/unomi.test.mjs",
    "test:integration:ai": "node --test tests/integration/ai.test.mjs",
    "test:integration:all": "npm run test:integration:local && RUN_AI_INTEGRATION_TESTS=1 npm run test:integration:ai:local",
    "test:integration:local": "node --env-file=.env.local --test tests/integration/unomi.test.mjs",
    "test:integration:ai:local": "node --env-file=.env.local --test tests/integration/ai.test.mjs",
    "test:app:integration": "node --test --test-concurrency=1 tests/integration/app/*.test.mjs",
    "test:app:integration:local": "node --env-file=.env.local --test --test-concurrency=1 tests/integration/app/*.test.mjs",
    "test:unit": "node --experimental-strip-types --test tests/unit/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:all:local": "npm run build && npm run test:unit && npm run test:integration:local && npm run test:app:integration:local && npm run test:e2e",
    "test:ci": "npm run build && npm run test:unit && npm run test:integration && npm run test:app:integration && npm run test:e2e"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.20.1"
  },
  "homepage": "https://retirement.inoyu.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inoyu-dev/inoyu-cdp-retirement-demo.git"
  },
  "bugs": {
    "url": "https://github.com/inoyu-dev/inoyu-cdp-retirement-demo/issues"
  }
}
